# Chỉ track file .html — tất cả file khác bị ignore

# Ignore everything
*

# Un-ignore thư mục (để git traverse vào bên trong)
!*/

# Re-ignore các thư mục không cần thiết
.venv/
/audio/
__pycache__/
node_modules/
.DS_Store
spec/

# content-pipeline (shorts video factory) — track source code, ignore artifacts
content-pipeline/.venv/
content-pipeline/cache/
content-pipeline/output/

# Un-ignore HTML files
!*.html

# Un-ignore shared JS
!*.js
!*.jsx

# Un-ignore docs/
!*.md

# Un-ignore styles & assets
!*.css
!*.svg

# Un-ignore JSON (package.json, data files)
!*.json

# Un-ignore chính file này
!.gitignore

# Un-ignore content-pipeline Python source (unlike scripts/, this is tracked)
!content-pipeline/**/*.py
!content-pipeline/**/requirements.txt
!content-pipeline/**/*.yaml
!content-pipeline/.env.example

# Un-ignore Vercel config
!vercel.json

# Un-ignore symlink vào sum-tech từ react-app/public
!react-app/public/sum-tech

# Un-ignore symlink vào workflows từ react-app/public
!react-app/public/workflows

# Re-ignore settings.local.json — chứa path máy cá nhân (username, home dir),
# KHÔNG được push lên GitHub. Rule này phải nằm SAU dòng "!*.json" ở trên để override.
.claude/settings.local.json
