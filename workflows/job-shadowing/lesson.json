  "conversations": [
    {
      "id": "conv-01",
      "title": "Shadowing a senior engineer",
      "title_vi": "Theo chân một kỹ sư cao cấp",
      "turns": [
        {
          "role": "Engineer",
          "text": "Thanks for letting me shadow you today.",
          "translation_vi": "Cảm ơn bạn đã cho tôi theo chân hôm nay.",
          "audio": "https://pub-66ce39e182bd45b2a7eb87242d51f36b.r2.dev/audio/en_277a982c9986.mp3",
          "phrases": [
            {
              "text": "Thanks for letting me",
              "audio": "https://pub-66ce39e182bd45b2a7eb87242d51f36b.r2.dev/audio/en_eb116736cdb8.mp3",
              "audio_slow": "https://pub-66ce39e182bd45b2a7eb87242d51f36b.r2.dev/audio/en_slow_c480baf6d79f.mp3"
            },
            {
              "text": "shadow you today.",
              "audio": "https://pub-66ce39e182bd45b2a7eb87242d51f36b.r2.dev/audio/en_32be462a5c69.mp3",
              "audio_slow": "https://pub-66ce39e182bd45b2a7eb87242d51f36b.r2.dev/audio/en_slow_7e89cd53e234.mp3"
            }
          ]
        },
        {
          "role": "Tech Lead",
          "text": "No problem. Happy to have you.",
          "translation_vi": "Không vấn đề gì. Vui khi có bạn.",
          "audio": "https://pub-66ce39e182bd45b2a7eb87242d51f36b.r2.dev/audio/en_4a068cd87d02.mp3"
        },
        {
          "role": "Engineer",
          "text": "I see you're opening the terminal first. What's your usual workflow?",
          "translation_vi": "Tôi thấy bạn mở terminal trước. Quy trình thông thường của bạn là gì?",
          "audio": "https://pub-66ce39e182bd45b2a7eb87242d51f36b.r2.dev/audio/en_e636cffdbea7.mp3",
          "phrases": [
            {
              "text": "I see you're opening the terminal first.",
              "audio": "https://pub-66ce39e182bd45b2a7eb87242d51f36b.r2.dev/audio/en_4b900e35801c.mp3",
              "audio_slow": "https://pub-66ce39e182bd45b2a7eb87242d51f36b.r2.dev/audio/en_slow_efc6319e3713.mp3"
            },
            {
              "text": "What's your usual workflow?",
              "audio": "https://pub-66ce39e182bd45b2a7eb87242d51f36b.r2.dev/audio/en_5449d06f3096.mp3",
              "audio_slow": "https://pub-66ce39e182bd45b2a7eb87242d51f36b.r2.dev/audio/en_slow_f071d406ba8b.mp3"
            }
          ]
        },
        {
          "role": "Tech Lead",
          "text": "I always pull the latest code and check for new issues.",
          "translation_vi": "Tôi luôn kéo code mới nhất và kiểm tra issue mới.",
          "audio": "https://pub-66ce39e182bd45b2a7eb87242d51f36b.r2.dev/audio/en_90eca208b71c.mp3"
        },
        {
          "role": "Engineer",
          "text": "Why did you choose this approach for the authentication service?",
          "translation_vi": "Tại sao bạn chọn cách tiếp cận này cho service xác thực?",
          "audio": "https://pub-66ce39e182bd45b2a7eb87242d51f36b.r2.dev/audio/en_fa1dccc11667.mp3",
          "phrases": [
            {
              "text": "Why did you choose this approach",
              "audio": "https://pub-66ce39e182bd45b2a7eb87242d51f36b.r2.dev/audio/en_64a769f6c077.mp3",
              "audio_slow": "https://pub-66ce39e182bd45b2a7eb87242d51f36b.r2.dev/audio/en_slow_632765c415e7.mp3"
            },
            {
              "text": "for the authentication service?",
              "audio": "https://pub-66ce39e182bd45b2a7eb87242d51f36b.r2.dev/audio/en_e15169ccb400.mp3",
              "audio_slow": "https://pub-66ce39e182bd45b2a7eb87242d51f36b.r2.dev/audio/en_slow_04f105d57353.mp3"
            }
          ]
        },
        {
          "role": "Tech Lead",
          "text": "It's more maintainable and scales better with our microservices.",
          "translation_vi": "Nó dễ bảo trì hơn và mở rộng tốt hơn với microservices của chúng ta.",
          "audio": "https://pub-66ce39e182bd45b2a7eb87242d51f36b.r2.dev/audio/en_3b78e8c99ff1.mp3"
        },
        {
          "role": "Engineer",
          "text": "Could you show me how you debug that issue?",
          "translation_vi": "Bạn có thể chỉ tôi cách bạn debug vấn đề đó không?",
          "audio": "https://pub-66ce39e182bd45b2a7eb87242d51f36b.r2.dev/audio/en_0e939b44d68f.mp3"
        },
        {
          "role": "Tech Lead",
          "text": "Sure. First, I check the logs and then reproduce it locally.",
          "translation_vi": "Chắc chắn. Đầu tiên, tôi kiểm tra log và tái hiện nó cục bộ.",
          "audio": "https://pub-66ce39e182bd45b2a7eb87242d51f36b.r2.dev/audio/en_a17ce1f22f69.mp3"
        },
        {
          "role": "Engineer",
          "text": "I learned a lot today. Thanks again for your time.",
          "translation_vi": "Hôm nay tôi học được nhiều. Cảm ơn bạn lần nữa.",
          "audio": "https://pub-66ce39e182bd45b2a7eb87242d51f36b.r2.dev/audio/en_7a1e31821648.mp3",
          "phrases": [
            {
              "text": "I learned a lot today.",
              "audio": "https://pub-66ce39e182bd45b2a7eb87242d51f36b.r2.dev/audio/en_a2690bf176b0.mp3",
              "audio_slow": "https://pub-66ce39e182bd45b2a7eb87242d51f36b.r2.dev/audio/en_slow_a6e066719a2b.mp3"
            },
            {
              "text": "Thanks again for your time.",
              "audio": "https://pub-66ce39e182bd45b2a7eb87242d51f36b.r2.dev/audio/en_f8d461c070a1.mp3",
              "audio_slow": "https://pub-66ce39e182bd45b2a7eb87242d51f36b.r2.dev/audio/en_slow_104b89da7ed4.mp3"
            }
          ]
        },
        {
          "role": "Tech Lead",
          "text": "You're welcome. Let me know if you have more questions later.",
          "translation_vi": "Không có gì. Hãy cho tôi biết nếu sau này bạn có thêm câu hỏi.",
          "audio": "https://pub-66ce39e182bd45b2a7eb87242d51f36b.r2.dev/audio/en_0c9228a2739a.mp3"
        }
      ]
    }
  ]
