{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["title", "description", "hashtags"],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "hashtags": {
      "type": "array",
      "items": { "type": "string", "pattern": "^#\\S+$" },
      "minItems": 1
    }
  },
  "additionalProperties": true
}
