{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Chinese Reading Lesson (by topic + HSK level)",
  "description": "Sinh bởi scripts/generate_zh_lesson.py. `pinyin` (pypinyin) và `audio` (edge-tts + R2) được điền SAU khi LLM trả về nội dung — không bắt buộc lúc validate raw LLM response.",
  "type": "object",
  "required": ["meta", "paragraphs"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["id", "topic_vi", "level", "title_zh", "title_vi", "created_at"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$", "description": "Trùng tên file zh-lesson-<id>.json" },
        "topic_vi": { "type": "string", "minLength": 1 },
        "level": { "type": "string", "pattern": "^HSK[1-6]$" },
        "title_zh": { "type": "string", "minLength": 1 },
        "title_vi": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string" }
      }
    },
    "paragraphs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "sentences"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "sentences": {
            "type": "array",
            "minItems": 1,
            "maxItems": 6,
            "description": "Tối đa 6 câu/đoạn — mỗi câu là 1 đơn vị nghe-lặp lại (audio) riêng.",
            "items": {
              "type": "object",
              "required": ["id", "zh", "vi", "phrases"],
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string" },
                "zh": { "type": "string", "minLength": 1, "description": "Câu tiếng Trung hoàn chỉnh, chỉ Hán tự + dấu câu." },
                "pinyin": { "type": "string", "description": "Sinh bằng pypinyin sau khi có `zh` — không do LLM viết." },
                "vi": { "type": "string", "minLength": 1, "description": "Bản dịch tự nhiên, không dịch máy móc từng chữ." },
                "audio": { "type": "string", "description": "URL R2 của audio câu này (tốc độ 0.75x). Rỗng cho tới khi chạy bước audio." },
                "phrases": {
                  "type": "array",
                  "minItems": 1,
                  "description": "Câu chia thành cụm nhỏ 2-5 chữ để người mới học đọc/nghe từng phần — nối `text` các phrase lại (không dấu cách) phải tái tạo đúng `zh`.",
                  "items": {
                    "type": "object",
                    "required": ["id", "text"],
                    "additionalProperties": false,
                    "properties": {
                      "id": { "type": "string" },
                      "text": { "type": "string", "minLength": 1 },
                      "pinyin": { "type": "string", "description": "Sinh bằng pypinyin." },
                      "audio": { "type": "string", "description": "URL R2 của audio cụm này (tốc độ 0.75x). Rỗng cho tới khi chạy bước audio." }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
